# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
CHANNEL_ID=-100xxxxxxxxxx          # Private channel ID (starts with -100)
BOT_USERNAME=YourBotUsername       # Without @

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox                # sandbox | live

# Run once: node src/paypal/createPlan.js — then paste the 4 plan IDs below:
PAYPAL_PLAN_ID_MONTHLY=P-xxxxxxxxxxxx
PAYPAL_PLAN_ID_QUARTERLY=P-xxxxxxxxxxxx
PAYPAL_PLAN_ID_BIANNUAL=P-xxxxxxxxxxxx
PAYPAL_PLAN_ID_ANNUAL=P-xxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
WEBHOOK_DOMAIN=https://your-app.onrender.com
WEBHOOK_SECRET=generate_a_random_32char_string_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=your_database_url_here

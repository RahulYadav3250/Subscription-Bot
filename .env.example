# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
CHANNEL_ID=-100xxxxxxxxxx
BOT_USERNAME=YourBotUsername

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Run once: node src/paypal/createPlan.js — paste the 4 IDs below:
PAYPAL_PLAN_ID_MONTHLY=P-xxxxxxxxxxxx
PAYPAL_PLAN_ID_QUARTERLY=P-xxxxxxxxxxxx
PAYPAL_PLAN_ID_BIANNUAL=P-xxxxxxxxxxxx
PAYPAL_PLAN_ID_ANNUAL=P-xxxxxxxxxxxx

# ── Supabase (PostgreSQL) ─────────────────────────────────────────────────────
# From: Supabase dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
WEBHOOK_DOMAIN=https://your-app.up.railway.app   # Your Railway public URL
WEBHOOK_SECRET=generate_a_random_32char_string_here
